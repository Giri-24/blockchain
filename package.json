{
  "name": "trustchain-blockchain",
  "version": "1.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "TrustChain - Fake Job Detection System Smart Contracts",
  "scripts": {
    "build": "npm --prefix frontend install && npm --prefix frontend run build && rm -rf public && cp -r frontend/build public",
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "npx hardhat run scripts/deploy.js --network sepolia",
    "node": "npx hardhat node",
    "clean": "npx hardhat clean",
    "start": "node api/index.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.28.6"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "js-sha256": "^0.11.1",
    "serverless-http": "^4.0.0"
  }
}
